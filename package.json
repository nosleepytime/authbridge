{
  "name": "authbridge-cloudflare-pages",
  "version": "1.0.0",
  "description": "Cloudflare Pages + D1 auth provider with sign up, sign in, consent screen, app approval workflow and Weglot-ready pages.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler pages dev public",
    "deploy": "wrangler pages deploy public",
    "d1:create": "wrangler d1 create authbridge-db",
    "d1:migrate:local": "wrangler d1 migrations apply AUTHBRIDGE_DB --local",
    "d1:migrate:remote": "wrangler d1 migrations apply AUTHBRIDGE_DB --remote"
  },
  "devDependencies": {
    "wrangler": "^4.8.0"
  }
}
